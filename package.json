{
  "name": "@ylakhdar/rspress-plugin-pretext-breaker",
  "version": "0.1.0",
  "description": "Add the Pretext Breaker game to an Rspress site.",
  "type": "module",
  "license": "MIT",
  "author": "Yassine Lakhdar",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/y-lakhdar/rspress-plugin-pretext-breaker.git"
  },
  "homepage": "https://y-lakhdar.github.io/rspress-plugin-pretext-breaker/",
  "bugs": {
    "url": "https://github.com/y-lakhdar/rspress-plugin-pretext-breaker/issues"
  },
  "keywords": [
    "rspress",
    "rspress-plugin",
    "pretext-breaker",
    "easter-egg",
    "breakout",
    "game"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "pack:dry": "pnpm pack --dry-run",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "knip": "knip"
  },
  "knip": {
    "entry": ["src/PretextBreakerGlobalUI.tsx"],
    "rules": {
      "duplicates": "off"
    }
  },
  "dependencies": {
    "@ylakhdar/pretext-breaker": "0.1.0"
  },
  "peerDependencies": {
    "@rspress/core": "^2.0.0",
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@rspress/core": "2.0.10",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "knip": "^6.13.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a"
}
